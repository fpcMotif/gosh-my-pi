{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "jq -r '.tool_response.filePath // .tool_input.file_path // empty' | { read -r f; case \"$f\" in *.ts|*.tsx|*.mts|*.cts|*.js|*.jsx|*.json) bunx oxfmt --write \"$f\";; esac; } 2>/dev/null || true"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "[ \"$(uname)\" = \"Darwin\" ] && (say -v Samantha 'Claude is done' >/dev/null 2>&1 &) ; true"
					}
				]
			}
		]
	},
	"permissions": {
		"allow": [
			"Bash(bun check:ts)",
			"Bash(bun check)",
			"Bash(bun fix:ts)",
			"Bash(bun fix)",
			"Bash(bun --cwd=packages/* test)",
			"Bash(bun --cwd=packages/* test:*)",
			"Bash(bun --cwd=packages/* run *)",
			"Bash(bunx oxfmt *)",
			"Bash(bunx oxlint *)",
			"Bash(bunx ultracite *)",
			"Bash(bun --cwd=packages/ai run generate-models)"
		]
	}
}
