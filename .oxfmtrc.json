{
	"useTabs": true,
	"tabWidth": 3,
	"printWidth": 120,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "avoid",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"ignorePatterns": [
		"packages/natives/native/index.d.ts",
		"**/vendor/**/*",
		"**/node_modules/**/*",
		"**/test-sessions.ts",
		"**/template.generated.ts",
		"**/docs-index.generated.ts",
		"**/gen/agent_pb.ts",
		".worktrees/**/*",
		".wt/**/*"
	]
}
