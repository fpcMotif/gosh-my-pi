{
	"type": "module",
	"private": true,
	"name": "@oh-my-pi/typescript-edit-benchmark",
	"version": "0.0.1",
	"description": "Edit benchmark suite using TypeScript source code mutations",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/typescript-edit-benchmark"
	},
	"main": "./src/index.ts",
	"bin": {
		"typescript-edit-benchmark": "src/index.ts"
	},
	"scripts": {
		"check": "oxfmt --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\" && oxlint --quiet --no-error-on-unmatched-pattern . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "oxlint --no-error-on-unmatched-pattern .",
		"test": "bun test",
		"fix": "oxfmt --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\" && oxlint --fix-dangerously --no-error-on-unmatched-pattern .",
		"fmt": "oxfmt --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\"",
		"generate": "bun run src/generate.ts --typescript-dir /tmp/pi-mono-source --count-per-type 4",
		"start": "bun run src/index.ts"
	},
	"dependencies": {
		"@babel/generator": "catalog:",
		"@babel/parser": "catalog:",
		"@babel/traverse": "catalog:",
		"@babel/types": "catalog:",
		"@oh-my-pi/pi-agent-core": "catalog:",
		"@oh-my-pi/pi-coding-agent": "catalog:",
		"@oh-my-pi/pi-utils": "catalog:",
		"diff": "catalog:",
		"prettier": "catalog:",
		"regexp-tree": "catalog:",
		"@oh-my-pi/pi-ai": "catalog:",
		"@oh-my-pi/pi-tui": "catalog:"
	},
	"devDependencies": {
		"@types/babel__generator": "catalog:",
		"@types/babel__traverse": "catalog:",
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
