{
	"name": "@oh-my-pi/pi-utils",
	"version": "14.5.11",
	"description": "Shared utilities for pi packages",
	"keywords": [
		"cli",
		"logging",
		"streams",
		"utilities"
	],
	"homepage": "https://github.com/can1357/oh-my-pi",
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"license": "MIT",
	"author": "Can Boluk",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/utils"
	},
	"files": [
		"src"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	},
	"scripts": {
		"check": "oxfmt --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\" && oxlint --quiet --no-error-on-unmatched-pattern . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit || true",
		"lint": "oxlint --no-error-on-unmatched-pattern .",
		"test": "bun test",
		"fix": "oxfmt --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\" && oxlint --fix-dangerously --no-error-on-unmatched-pattern .",
		"fmt": "oxfmt --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \"src/**/*.tsx\" \"test/**/*.ts\" \"examples/**/*.ts\" \"scripts/**/*.ts\" \"*.ts\""
	},
	"dependencies": {
		"beautiful-mermaid": "catalog:",
		"handlebars": "catalog:",
		"winston": "catalog:",
		"winston-daily-rotate-file": "catalog:"
	},
	"devDependencies": {
		"@oh-my-pi/pi-natives": "catalog:",
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
